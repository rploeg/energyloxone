@page
@model LoxoneSolarForecast.Pages.ErrorModel
@{
    ViewData["Title"] = "Error";
}

<div class="text-center py-5">
    <i class="bi bi-exclamation-triangle text-danger" style="font-size:4rem"></i>
    <h2 class="mt-3">An error occurred.</h2>
    @if (Model.ShowRequestId)
    {
        <p class="text-secondary">Request ID: <code>@Model.RequestId</code></p>
    }
    <a asp-page="/Index" class="btn btn-warning mt-3">
        <i class="bi bi-house me-2"></i>Back to Dashboard
    </a>
</div>
