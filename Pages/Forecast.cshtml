@page
@model LoxoneSolarForecast.Pages.ForecastModel
@{
    ViewData["Title"] = "Forecast";
    var f = Model.Forecast;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-cloud-sun text-warning me-2"></i>Solar Forecast</h4>
    <small class="text-secondary">Generated: @f.LastGenerated.ToLocalTime().ToString("dd/MM HH:mm")</small>
</div>

<!-- Today/Tomorrow Summary -->
<div class="row g-3 mb-4">
    <div class="col-12 col-md-6">
        <div class="card border-warning">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <h5>Today</h5>
                        <div class="fs-1 fw-bold text-warning">@f.TodayKwh.ToString("F1") <span class="fs-5">kWh</span></div>
                        <div class="text-secondary">Peak: @(f.TodayPeakTime.HasValue ? f.TodayPeakTime.Value.ToLocalTime().ToString("HH:mm") : "--") at @((f.TodayPeakWatts/1000).ToString("F1")) kW</div>
                    </div>
                    <div class="text-end">
                        <div class="badge bg-success fs-6">@f.TodayConfidence.ToString("F0")%</div>
                        <div class="small text-secondary mt-1">Confidence</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6">
        <div class="card">
            <div class="card-body">
                <h5>Tomorrow</h5>
                <div class="fs-1 fw-bold">@f.TomorrowKwh.ToString("F1") <span class="fs-5">kWh</span></div>
                <div class="text-secondary">Forecast for next day</div>
            </div>
        </div>
    </div>
</div>

<!-- Hourly Chart -->
<div class="card mb-4">
    <div class="card-header"><i class="bi bi-bar-chart me-2"></i>Today Hourly Forecast</div>
    <div class="card-body">
        <canvas id="todayHourly" height="80"></canvas>
    </div>
</div>

<!-- Tomorrow Hourly Chart -->
<div class="card mb-4">
    <div class="card-header"><i class="bi bi-bar-chart me-2"></i>Tomorrow Hourly Forecast</div>
    <div class="card-body">
        <canvas id="tomorrowHourly" height="80"></canvas>
    </div>
</div>

<!-- 7-Day Table -->
<div class="card">
    <div class="card-header"><i class="bi bi-calendar3-week me-2"></i>7-Day Forecast</div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-dark table-hover mb-0">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Forecast (kWh)</th>
                        <th>Peak Power</th>
                        <th>Peak Time</th>
                        <th>Cloud Cover</th>
                        <th>Confidence</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var day in f.DailyForecasts)
                    {
                        <tr class="@(day.IsToday ? "table-warning" : day.IsTomorrow ? "table-secondary" : "")">
                            <td>
                                @day.Date.ToString("ddd dd/MM")
                                @if (day.IsToday) { <span class="badge bg-warning text-dark ms-1">Today</span> }
                                @if (day.IsTomorrow) { <span class="badge bg-secondary ms-1">Tomorrow</span> }
                            </td>
                            <td class="fw-bold">@day.ForecastedKwh.ToString("F2") kWh</td>
                            <td>@((day.PeakWatts/1000).ToString("F2")) kW</td>
                            <td>@(day.PeakTime.HasValue ? day.PeakTime.Value.ToLocalTime().ToString("HH:mm") : "--")</td>
                            <td>
                                <div class="progress" style="height:16px; min-width:80px">
                                    <div class="progress-bar bg-secondary" style="width:@((int)day.CloudCoverPercent)%">@((int)day.CloudCoverPercent)%</div>
                                </div>
                            </td>
                            <td>
                                <div class="progress" style="height:16px; min-width:80px">
                                    <div class="progress-bar bg-success" style="width:@((int)day.ConfidencePercent)%">@((int)day.ConfidencePercent)%</div>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
<script>
Chart.defaults.color = '#adb5bd';

const todayLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(f.TodayHourly.Select(h => h.Hour.ToLocalTime().ToString("HH:mm"))));
const todayWh = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(f.TodayHourly.Select(h => Math.Round(h.ForecastedWh, 1))));
const todayCloud = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(f.TodayHourly.Select(h => Math.Round(h.CloudCoverPercent, 1))));

new Chart(document.getElementById('todayHourly'), {
    type: 'bar',
    data: {
        labels: todayLabels,
        datasets: [
            { label: 'Production (Wh)', data: todayWh, backgroundColor: 'rgba(255,193,7,0.7)', borderColor: '#ffc107', yAxisID: 'y' },
            { label: 'Cloud Cover (%)', data: todayCloud, type: 'line', borderColor: '#6c757d', backgroundColor: 'rgba(108,117,125,0.1)', fill: true, tension: 0.3, pointRadius: 2, yAxisID: 'y1' }
        ]
    },
    options: { responsive: true, plugins: { legend: { position: 'top' } }, scales: { x: { grid: { color: '#333' } }, y: { grid: { color: '#333' }, beginAtZero: true, position: 'left' }, y1: { grid: { display: false }, beginAtZero: true, max: 100, position: 'right' } } }
});

const tomorrowLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(f.TomorrowHourly.Select(h => h.Hour.ToLocalTime().ToString("HH:mm"))));
const tomorrowWh = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(f.TomorrowHourly.Select(h => Math.Round(h.ForecastedWh, 1))));

new Chart(document.getElementById('tomorrowHourly'), {
    type: 'bar',
    data: { labels: tomorrowLabels, datasets: [{ label: 'Production (Wh)', data: tomorrowWh, backgroundColor: 'rgba(13,202,240,0.6)', borderColor: '#0dcaf0', borderWidth: 1 }] },
    options: { responsive: true, plugins: { legend: { display: false } }, scales: { x: { grid: { color: '#333' } }, y: { grid: { color: '#333' }, beginAtZero: true } } }
});
</script>
}
