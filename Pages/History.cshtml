@page
@model LoxoneSolarForecast.Pages.HistoryModel
@{
    ViewData["Title"] = "History";
    var h = Model.History;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-bar-chart-line text-warning me-2"></i>Production History</h4>
</div>

<!-- Period Filter -->
<div class="btn-group mb-3">
    <a asp-page="/History" asp-route-period="today" class="btn @(h.Period == "today" ? "btn-warning" : "btn-outline-secondary")">Today</a>
    <a asp-page="/History" asp-route-period="week" class="btn @(h.Period == "week" ? "btn-warning" : "btn-outline-secondary")">Last 7 Days</a>
    <a asp-page="/History" asp-route-period="month" class="btn @(h.Period == "month" ? "btn-warning" : "btn-outline-secondary")">Last Month</a>
    <a asp-page="/History" asp-route-period="year" class="btn @(h.Period == "year" ? "btn-warning" : "btn-outline-secondary")">Last Year</a>
</div>

<!-- Summary KPIs -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="card text-center"><div class="card-body">
            <div class="fs-3 fw-bold text-warning">@h.TotalProductionKwh.ToString("F1")</div>
            <div class="small text-secondary">kWh Produced</div>
        </div></div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card text-center"><div class="card-body">
            <div class="fs-3 fw-bold">@h.TotalConsumptionKwh.ToString("F1")</div>
            <div class="small text-secondary">kWh Consumed</div>
        </div></div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card text-center"><div class="card-body">
            <div class="fs-3 fw-bold text-success">@h.TotalExportKwh.ToString("F1")</div>
            <div class="small text-secondary">kWh Exported</div>
        </div></div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card text-center"><div class="card-body">
            <div class="fs-3 fw-bold text-info">@h.ForecastAccuracyPercent.ToString("F0")%</div>
            <div class="small text-secondary">Forecast Accuracy</div>
        </div></div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card text-center"><div class="card-body">
            <div class="fs-3 fw-bold">@h.AverageDailyKwh.ToString("F2")</div>
            <div class="small text-secondary">kWh Avg/Day</div>
        </div></div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card text-center"><div class="card-body">
            <div class="fs-3 fw-bold text-warning">@h.BestDayKwh.ToString("F2")</div>
            <div class="small text-secondary">Best Day kWh @(h.BestDay.HasValue ? h.BestDay.Value.ToString("dd/MM") : "")</div>
        </div></div>
    </div>
</div>

<!-- Production Chart -->
<div class="card mb-4">
    <div class="card-header"><i class="bi bi-sun me-2"></i>Daily Production vs Forecast</div>
    <div class="card-body">
        <canvas id="prodChart" height="80"></canvas>
    </div>
</div>

<!-- Consumption / Export Chart -->
<div class="card mb-4">
    <div class="card-header"><i class="bi bi-house me-2"></i>Consumption &amp; Export</div>
    <div class="card-body">
        <canvas id="consChart" height="80"></canvas>
    </div>
</div>

<!-- Data Table -->
<div class="card">
    <div class="card-header"><i class="bi bi-table me-2"></i>Daily Data</div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-dark table-hover table-sm mb-0">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Production (kWh)</th>
                        <th>Forecast (kWh)</th>
                        <th>Consumption (kWh)</th>
                        <th>Export (kWh)</th>
                        <th>Battery SOC</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var day in h.DailyItems.OrderByDescending(d => d.Date))
                    {
                        <tr>
                            <td>@day.Date.ToString("ddd dd/MM/yyyy")</td>
                            <td class="text-warning fw-bold">@day.ProductionKwh.ToString("F2")</td>
                            <td class="text-secondary">@(day.ForecastKwh.HasValue ? day.ForecastKwh.Value.ToString("F2") : "—")</td>
                            <td>@day.ConsumptionKwh.ToString("F2")</td>
                            <td class="text-success">@day.ExportKwh.ToString("F2")</td>
                            <td>
                                @if (day.BatteryMinSoc.HasValue)
                                {
                                    <span>@day.BatteryMinSoc.Value.ToString("F0")% – @day.BatteryMaxSoc!.Value.ToString("F0")%</span>
                                }
                                else { <span class="text-secondary">—</span> }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
<script>
Chart.defaults.color = '#adb5bd';
const labels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(h.DailyItems.Select(d => d.Date.ToString("dd/MM"))));
const prod = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(h.DailyItems.Select(d => Math.Round(d.ProductionKwh, 2))));
const forecast = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(h.DailyItems.Select(d => d.ForecastKwh.HasValue ? Math.Round(d.ForecastKwh.Value, 2) : (double?)null)));
const cons = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(h.DailyItems.Select(d => Math.Round(d.ConsumptionKwh, 2))));
const exp = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(h.DailyItems.Select(d => Math.Round(d.ExportKwh, 2))));

new Chart(document.getElementById('prodChart'), {
    data: {
        labels,
        datasets: [
            { type: 'bar', label: 'Actual (kWh)', data: prod, backgroundColor: 'rgba(255,193,7,0.7)', borderColor: '#ffc107' },
            { type: 'line', label: 'Forecast (kWh)', data: forecast, borderColor: '#0dcaf0', borderDash: [5,3], tension: 0.3, pointRadius: 3, fill: false }
        ]
    },
    options: { responsive: true, plugins: { legend: { position: 'top' } }, scales: { x: { grid: { color: '#333' } }, y: { grid: { color: '#333' }, beginAtZero: true } } }
});

new Chart(document.getElementById('consChart'), {
    type: 'bar',
    data: {
        labels,
        datasets: [
            { label: 'Consumption (kWh)', data: cons, backgroundColor: 'rgba(108,117,125,0.7)', borderColor: '#6c757d' },
            { label: 'Export (kWh)', data: exp, backgroundColor: 'rgba(25,135,84,0.7)', borderColor: '#198754' }
        ]
    },
    options: { responsive: true, plugins: { legend: { position: 'top' } }, scales: { x: { grid: { color: '#333' } }, y: { grid: { color: '#333' }, beginAtZero: true } } }
});
</script>
}
