<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — @ViewData["AppName"]</title>
    @inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
    @{ var token = Antiforgery.GetAndStoreTokens(Context).RequestToken; }
    <meta name="csrf-token" content="@token" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark border-bottom border-secondary">
        <div class="container-fluid">
            <a class="navbar-brand d-flex align-items-center gap-2" asp-page="/Index">
                <i class="bi bi-sun-fill text-warning fs-4"></i>
                <span>@ViewData["AppName"]</span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Index"><i class="bi bi-speedometer2 me-1"></i>Dashboard</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Forecast"><i class="bi bi-cloud-sun me-1"></i>Forecast</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Recommendations"><i class="bi bi-lightning-charge me-1"></i>Optimize</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/History"><i class="bi bi-bar-chart-line me-1"></i>History</a>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                            <i class="bi bi-gear me-1"></i>Settings
                        </a>
                        <ul class="dropdown-menu dropdown-menu-dark">
                            <li><a class="dropdown-item" asp-page="/Configuration"><i class="bi bi-sliders me-2"></i>Configuration</a></li>
                            <li><a class="dropdown-item" asp-page="/SolarArrays"><i class="bi bi-solar-panel me-2"></i>Solar Arrays</a></li>
                            <li><a class="dropdown-item" asp-page="/Location"><i class="bi bi-geo-alt me-2"></i>Location</a></li>
                        </ul>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                            <i class="bi bi-activity me-1"></i>System
                        </a>
                        <ul class="dropdown-menu dropdown-menu-dark">
                            <li><a class="dropdown-item" asp-page="/Monitoring"><i class="bi bi-heart-pulse me-2"></i>Monitoring</a></li>
                            <li><a class="dropdown-item" asp-page="/Logs"><i class="bi bi-journal-text me-2"></i>Logs</a></li>
                        </ul>
                    </li>
                </ul>
                <span class="navbar-text text-secondary small">
                    <i class="bi bi-clock me-1"></i>
                    <span id="clock"></span>
                </span>
            </div>
        </div>
    </nav>

    <main class="container-fluid py-3">
        @RenderBody()
    </main>

    <footer class="border-top border-secondary text-center text-secondary small py-2 mt-4">
        LoxoneSolarForecast &copy; @DateTime.Now.Year — Solar Energy Intelligence for Loxone
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
        // Live clock
        function updateClock() {
            document.getElementById('clock').textContent = new Date().toLocaleTimeString();
        }
        setInterval(updateClock, 1000);
        updateClock();

        // Active nav link
        document.querySelectorAll('.nav-link').forEach(link => {
            if (link.href === window.location.href) link.classList.add('active');
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
